# wrangler files
.wrangler
.dev.vars*
!.dev.vars.example
.env*
!.env.example

# macOS
.DS_Store

# Local deploy scripts — they contain your GitHub token. NEVER publish them.
*.command

# Local-only folders (not part of the deployable game):
#   _reference  — reference docs, briefs, PDFs
#   _archive    — old/legacy assets, screenshots
#   _source-art — high-res source PNGs used to generate the production assets
#                 (characters/, coaches/, pasos-footprints.png)
# NOTE: Pasos's index.html references cortadito-orange.png + pasos-footprints.png
# at root, plus everything in characters/ and coaches/ — so those must ship.
_reference/
_archive/
_source-art/

# Reference drops — never belong in the deployed game.
# (We deliberately do NOT ignore *.png at root because the game ships two of them.)
*.pdf
*.webp
*.jpg
*.jpeg
